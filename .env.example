# =============================================================================
# Monolith Platform — Environment Variables
# Copy to .env for local development (Docker Compose loads this automatically)
# =============================================================================

# --- Application ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Web (Next.js) — apps/web ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- API (NestJS) — apps/api ---
API_HOST=0.0.0.0
API_PORT=3001
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
# Local Docker: postgresql://monolith:monolith@localhost:5432/monolith
# Production (Supabase): use Supabase connection string
DATABASE_URL=postgresql://monolith:monolith@localhost:5432/monolith?schema=public
DIRECT_URL=postgresql://monolith:monolith@localhost:5432/monolith?schema=public

# --- Redis ---
# Local Docker: redis://localhost:6379
# Production (Upstash): use Upstash Redis URL
REDIS_URL=redis://localhost:6379

# --- BullMQ ---
BULLMQ_PREFIX=monolith

# --- Auth (configure when implementing) ---
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# --- External services (production) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
